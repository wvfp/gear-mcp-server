{
  "name": "gear-godot-mcp",
  "version": "1.0.1",
  "mcpName": "io.github.wvfp/gear-godot-mcp",
  "description": "Gear — MCP server for Godot Engine with 110+ tools, compact/dynamic profiles, GDScript LSP, DAP debugger, screenshots, input injection, and CC0 asset search.",
  "type": "module",
  "main": "./build/index.js",
  "bin": {
    "gear": "./build/cli.js",
    "godot-mcp": "./build/cli.js"
  },
  "files": [
    "build",
    "scripts/postinstall.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-visualizer.js && node scripts/build.js",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/smoke-test.mjs",
    "ci": "npm run build && npm run typecheck && npm run test",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall.mjs",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "pack": "npm pack --dry-run",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "fs-extra": "^11.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.24.2",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@hono/node-server": "^1.19.11",
    "hono": "4.12.7",
    "path-to-regexp": "8.4.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wvfp/Gear-godot-mcp.git"
  },
  "homepage": "https://github.com/wvfp/Gear-godot-mcp#readme",
  "bugs": {
    "url": "https://github.com/wvfp/Gear-godot-mcp/issues"
  },
  "author": {
    "name": "wvfp",
    "url": "https://github.com/wvfp"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/wvfp"
  },
  "keywords": [
    "gear",
    "gear-godot-mcp",
    "godot",
    "godot-engine",
    "godot4",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai",
    "ai-tools",
    "ai-integration",
    "claude",
    "cline",
    "opencode",
    "cursor",
    "game-development",
    "gamedev",
    "game-engine",
    "gdscript",
    "language-server",
    "lsp",
    "dap",
    "debug-adapter-protocol",
    "screenshot",
    "input-injection",
    "auto-reload",
    "developer-tools",
    "typescript"
  ]
}
